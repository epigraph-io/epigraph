{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                id, agent_id, public_key, key_type, status,\n                valid_from, valid_until, revocation_reason, revoked_by, created_at\n            FROM agent_keys\n            WHERE agent_id = $1\n              AND status = 'active'\n            ORDER BY created_at DESC\n            LIMIT 1\n            ",
