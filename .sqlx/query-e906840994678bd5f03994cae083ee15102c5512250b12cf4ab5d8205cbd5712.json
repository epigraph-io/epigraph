  "query": "\n            SELECT id, canonical_name, type_top, type_sub, properties, is_canonical,\n                   merged_into, created_at\n            FROM entities\n            WHERE lower(canonical_name) = lower($1)\n              AND type_top = $2\n              AND is_canonical = true\n            ",
