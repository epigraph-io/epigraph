  "query": "\n            SELECT id, public_key, display_name, created_at, labels, orcid, ror_id\n            FROM agents\n            WHERE $1 = ANY(labels)\n            ORDER BY created_at DESC\n            LIMIT $2 OFFSET $3\n            ",
