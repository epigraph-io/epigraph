  "query": "\n            SELECT id, source_id, source_type, target_id, target_type, relationship, properties, valid_from, valid_to\n            FROM edges\n            WHERE (source_id = $1 OR target_id = $1)\n              AND relationship = $2\n              AND valid_to IS NULL\n            ORDER BY valid_from DESC NULLS LAST\n            ",
